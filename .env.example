# Shopify credentials
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_ADMIN_API_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxx
SHOPIFY_API_VERSION=2024-10

# Warehouse location ID (numeric or full GID) - orders assigned here are protected
# e.g. 12345678 or gid://shopify/Location/12345678
WAREHOUSE_LOCATION_ID=gid://shopify/Location/12345678

# Allowed reroute destination location IDs (comma-separated, exclude warehouse)
# Staff can only send orders TO these locations
ALLOWED_LOCATION_IDS=gid://shopify/Location/11111,gid://shopify/Location/22222,gid://shopify/Location/33333

# Users: username:password:locationId — one per line, separated by semicolons
# locationId must match a Shopify location GID (or numeric ID)
# Example:
USERS=alice:pass123:gid://shopify/Location/11111;bob:pass456:gid://shopify/Location/22222;carol:pass789:gid://shopify/Location/33333

# Admin password for viewing audit logs at /admin
ADMIN_PASSWORD=adminpass123

# Port
PORT=3000
